{
  "name": "{{ cookiecutter.project_slug }}",
  "version": "0.1.0",
  "description": "{{ cookiecutter.description }}",
  "type": "module",
  "bin": {
    "{{ cookiecutter.command_name }}": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@types/node": "24.3.1",
    "typescript": "5.9.3"
  }
}
